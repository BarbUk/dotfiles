set -o errexit -o pipefail -o nounset

current_dir="$PWD"

if ! [ -f PKGBUILD ]; then
  echo "Not an archlinux package"
  exit 1
fi

if [ -f .nvchecker.toml ]; then
  echo ".nvchecker.toml already exists"
  exit 1
fi

pkgbase=$(basename "$current_dir")
url=$(sed -n 's/^url=//p' PKGBUILD | tr -d \"\')

case "$url" in
  *"github"*)
    source=github
    ;;
  *"gitlab"*)
    source=gitlab
    ;;
esac

if [ -z "$source" ]; then
  echo "No source detected"
  exit 1
fi

# Remove https
url="${url#*://}"
# Keep only repo
url="${url#*/}"

prefix=''

# shellcheck disable=SC2016
if grep -qF -e 'v$pkgver' -e '$v${pkgver}' PKGBUILD; then
  prefix='prefix = "v"'
fi

cat <<EOF >.nvchecker.toml
[$pkgbase]
source = "$source"
$source = "$url"
use_max_tag = true
$prefix
EOF
