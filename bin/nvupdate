set -o errexit -o pipefail -o nounset

while read -r package _ _ new_version; do
  message="$package: $new_version: upstream release"
  cd "$HOME/ztemp/packages/$package" || continue
  sed -r -i -e "s/^pkgver=(.*)$/pkgver=${new_version/-/.}/g" -e 's/^pkgrel=(.*)$/pkgrel=1/g' PKGBUILD
  updpkgsums
  makepkg --printsrcinfo >.SRCINFO
  if pkgctl build; then
    git add PKGBUILD .SRCINFO
    git commit -m "$message"
  fi
done <<<"$(nvcmp)"

# Display information
nvcmp

