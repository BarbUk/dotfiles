set -o errexit -o pipefail -o nounset

dmenu="rofi -dmenu -i -sort -lines 25 -p vpn"

if [[ -t 0 ]]; then
  dmenu="fzf --select-1 --reverse --inline-info"
fi

vpn="$(nmcli connection show | awk '$3 ~ /^(vpn|wireguard)$/ {print $1}' | ${dmenu})"
enabled_vpn="$(nmcli connection show --active | awk '$3 ~ /^(vpn|wireguard)$/ {print $1}')"

if [ -n "$enabled_vpn" ]; then
  nmcli connection down "$enabled_vpn" >/dev/null 2>&1
fi

nmcli connection up "$vpn" >/dev/null 2>&1
