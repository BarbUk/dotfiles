# List your chrome history.
# You can use it in rofi to open a link
# Example: rofi -combi-modi "clipboard:greenclip print,chrome:chrome_history,window,drun" -show combi -modi combi -lines 25  -display-combi '> '

set -o errexit -o pipefail -o nounset

tmpfile=$(mktemp)
readonly tmpfile
trap 'rm -f $tmpfile' EXIT HUP INT TRAP TERM

sep='<>'
if [ "$(uname)" = "Darwin" ]; then
  mapfile -t chrome_history_files < <(find "$HOME/Library/Application Support/Google/Chrome/" -maxdepth 2 -type f -name History)
  open=open
else
  mapfile -t chrome_history_files < <(find "$HOME/.config/google-chrome/" -maxdepth 2 -type f -name History)
  open=xdg-open
fi

# If we have an input, extract the url and open it in the default browser
if [ ! -z ${1+x} ]; then
  $open "${1##*"$sep"}" >/dev/null 2>&1
  exit 0
fi

extract_chrome_history() {
  local history_file=$1
  cp -f "$history_file" "$tmpfile"
  # shellcheck disable=2086
  sqlite3 -separator $sep "$tmpfile" \
    "SELECT substr(title, 1, 50) as label, url
      FROM urls
      GROUP BY label
      ORDER BY last_visit_time DESC
      LIMIT 50"
}

for chrome_history_file in "${chrome_history_files[@]}"; do
  extract_chrome_history "$chrome_history_file"
done
