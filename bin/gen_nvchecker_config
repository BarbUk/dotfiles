set -o errexit -o pipefail -o nounset

config="$XDG_CONFIG_HOME/nvchecker/nvchecker.toml"
old="$XDG_CONFIG_HOME/nvchecker/old.json"
packages_dir="$HOME/ztemp/packages"

cat >"$config" <<__EOF__
[__config__]
oldver = "old.json"
newver = "new.json"
keyfile = "keys.toml"
__EOF__

tmpfile=$(mktemp)
trap 'rm -f $tmpfile' EXIT

for package in "$packages_dir"/*/.nvchecker.toml; do
  echo >>"$config"
  cat "$package" >>"$config"
  pkgdir=$(dirname "$package")
  pkgbase=$(basename "$pkgdir")
  pkgver=$(sed -n 's/^pkgver=//p' "$pkgdir/PKGBUILD" | tr -d \"\')
  if grep -q ^_pkgrelease "$pkgdir/PKGBUILD"; then
    pkgver+=$(sed -n 's/^_pkgrelease=//p' "$pkgdir/PKGBUILD" | tr -d \"\')
  fi
  echo "Detected $pkgbase: $pkgver"
  printf '{"%s": "%s"}\n' "$pkgbase" "$pkgver" >>"$tmpfile"
done

jq -s add "$tmpfile" >"$old"
