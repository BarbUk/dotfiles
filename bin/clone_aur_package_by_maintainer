set -o errexit -o pipefail -o nounset

maintainer="$1"

curl -s "https://aur.archlinux.org/rpc/v5/search/${maintainer}?by=maintainer" | jq -r .results[].PackageBase | while read -r package; do
  if [ -d "$package" ]; then
    echo "$package already cloned"
    continue
  fi

  git clone --quiet "ssh://aur@aur.archlinux.org/$package"

done
